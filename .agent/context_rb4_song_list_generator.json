    "generator": "/workspace/RB4/generate_rb4_song_list.js",
    "backup": "/workspace/RB4/scripts/backup_rb4_run.sh",
    "restore": "/workspace/RB4/scripts/restore_rb4_run.sh"
  },
  "key_files": {
    "baseline": "/workspace/RB4/rb4songlistWithRivals.txt",
