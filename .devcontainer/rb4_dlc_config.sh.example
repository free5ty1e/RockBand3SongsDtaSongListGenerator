# Custom RB4 DLC SMB configuration - EXAMPLE FILE
# Copy to rb4_dlc_config.sh and customize

# SMB server IP (default: 192.168.100.135)
# SMB_SERVER="192.168.100.135"

# SMB share path - format: "sharename" or "sharename/subfolder/..."
# Example: "incoming/temp/Rb4Dlc" or just "incoming"
# SMB_SHARE="incoming/temp/Rb4Dlc"

# HTML page title (default: 🎸 Rock Band 4 Song List)
# HTML_PAGE_TITLE="🎸 Rock Band 4 Song List"
